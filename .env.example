# ============================================================
# 环境变量配置示例
# ============================================================
# 复制此文件为 .env 并填入实际值
# .env 文件不应提交到版本控制

# LLM API Key（敏感信息）
MINIMAX_API_KEY=your-api-key-here

# 或者 Ollama 配置
# OLLAMA_BASE_URL=http://localhost:11434/v1

# 数据库密码（如果使用 MySQL）
# DB_PASSWORD=your-db-password
